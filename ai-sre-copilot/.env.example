# ─────────────────────────────────────────────
#  AI SRE Copilot — Environment Variables
#  Copy this to .env and fill in your values
# ─────────────────────────────────────────────

# ── App ───────────────────────────────────────
APP_ENV=development
APP_HOST=0.0.0.0
APP_PORT=8000
LOG_LEVEL=INFO

# ── PostgreSQL ────────────────────────────────
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=sre_copilot
POSTGRES_USER=sre_user
POSTGRES_PASSWORD=sre_pass
DATABASE_URL=postgresql+asyncpg://sre_user:sre_pass@localhost:5432/sre_copilot

# ── Redis ─────────────────────────────────────
REDIS_URL=redis://localhost:6379/0
REDIS_HITL_TTL=3600        # HITL decision ka timeout (seconds)

# ── Kafka ─────────────────────────────────────
KAFKA_BOOTSTRAP_SERVERS=localhost:9092
KAFKA_TOPIC_ALERTS=incident.alerts
KAFKA_TOPIC_STATUS=incident.status
KAFKA_TOPIC_HITL=hitl.decisions
KAFKA_CONSUMER_GROUP=sre-copilot-group

# ── Qdrant ────────────────────────────────────
QDRANT_HOST=localhost
QDRANT_PORT=6333
QDRANT_COLLECTION=runbooks
QDRANT_VECTOR_SIZE=384      # all-MiniLM-L6-v2 ka output size

# ── Prometheus ────────────────────────────────
PROMETHEUS_URL=http://localhost:9090

# ── Loki ──────────────────────────────────────
LOKI_URL=http://localhost:3100

# ── Tempo ─────────────────────────────────────
TEMPO_URL=http://localhost:3200

# ── Ollama (Local LLM) ────────────────────────
OLLAMA_URL=http://localhost:11434
OLLAMA_MODEL=qwen2.5:7b      # Ya llama3.2:3b lightweight ke liye
OLLAMA_TIMEOUT=120

# ── Notifications (baad mein fill karna) ──────
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/YOUR/WEBHOOK/URL
JIRA_URL=https://your-org.atlassian.net
JIRA_EMAIL=your@email.com
JIRA_API_TOKEN=your-jira-token
JIRA_PROJECT_KEY=SRE
